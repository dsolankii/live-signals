# LeadGrid local environment example
# Copy this file to .env.local and fill real values.
# Never commit .env.local.

# Gemini / Google AI API key used by scripts/enrich-company-batch-ai.mjs
GEMINI_API_KEY=your_gemini_api_key_here

# Optional aliases if your script checks these names
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENERATIVE_AI_API_KEY=your_google_generative_ai_api_key_here

# App URL for local testing
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional model override
GEMINI_MODEL=gemini-3.1-flash-lite
